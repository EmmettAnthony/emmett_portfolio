  phone         String?
  position      String?
  companyId     String?
  company       CrmCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  industry      String?
  website       String?
  healthScore   Int      @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  leads         CrmLead[]            @relation("LeadToClient")
  deals         CrmDeal[]
  contracts     CrmContract[]
  invoices      CrmInvoice[]
  proposals     CrmProposal[]
  projects      PortfolioProject[]   @relation("ClientProjects")
  activities    CrmActivity[]
  tasks         CrmTask[]
  communications CrmCommunication[]

  @@index([email])
  @@index([companyId])
  @@map("crm_clients")
}

model CrmCompany {
  id            String   @id @default(cuid())
  name          String
  industry      String?
  website       String?
  address       String?
  companySize   String?
  annualRevenue Float?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  clients       CrmClient[]
  deals         CrmDeal[]

  @@index([name])
  @@map("crm_companies")
}

model CrmDeal {
  id                String    @id @default(cuid())
  name              String
  value             Float     @default(0)
  probability       Int       @default(0)
  expectedCloseDate DateTime?
  stage             String    @default("NEW_LEAD") // NEW_LEAD, DISCOVERY, QUALIFIED, PROPOSAL_SENT, NEGOTIATION, WON, LOST
  lostReason        String?
  notes             String?
  leadId            String?
  lead              CrmLead?  @relation(fields: [leadId], references: [id], onDelete: SetNull)
  clientId          String?
  client            CrmClient? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  companyId         String?
  company           CrmCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  activities        CrmActivity[]
  tasks             CrmTask[]

  @@index([stage])
  @@index([clientId])
  @@index([leadId])
  @@map("crm_deals")
}

model CrmActivity {
  id          String    @id @default(cuid())
  type        String    // CALL, EMAIL, MEETING, NOTE, TASK, FOLLOW_UP
  subject     String
  description String?
  date        DateTime  @default(now())
  duration    Int?
  completed   Boolean   @default(false)
  leadId      String?
  lead        CrmLead?  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  clientId    String?
  client      CrmClient? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dealId      String?
  deal        CrmDeal?  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  assignedTo  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type])
  @@index([date])
  @@index([leadId])
  @@index([clientId])
  @@map("crm_activities")
}

model CrmTask {
  id          String    @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  leadId      String?
  lead        CrmLead?  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  clientId    String?
  client      CrmClient? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dealId      String?
  deal        CrmDeal?  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  assignedTo  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([dueDate])
  @@index([leadId])
  @@index([clientId])
  @@map("crm_tasks")
}

model CrmProposal {
