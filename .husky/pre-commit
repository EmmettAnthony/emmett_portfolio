echo "🔍 Running pre-commit checks..."
echo ""

# 1. ESLint
echo "📝 Running ESLint..."
npm run lint
if [ $? -ne 0 ]; then
  echo "❌ ESLint failed. Fix errors before committing."
  exit 1
fi
echo "✅ ESLint passed"
echo ""

# 2. TypeScript Check
echo "🔎 Running TypeScript check..."
npm run type-check
if [ $? -ne 0 ]; then
  echo "❌ TypeScript check failed. Fix errors before committing."
  exit 1
fi
echo "✅ TypeScript check passed"
echo ""

# 3. Unit & Component Tests (fast subset)
echo "🧪 Running unit and component tests..."
npx vitest run tests/unit/ tests/component/ --reporter=verbose
if [ $? -ne 0 ]; then
  echo "❌ Tests failed. Fix errors before committing."
  exit 1
fi
echo "✅ Tests passed"
echo ""

echo "🎉 All pre-commit checks passed!"
