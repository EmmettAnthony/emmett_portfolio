echo "🔍 Running pre-commit checks..."
echo ""

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# 1. ESLint on staged files only
echo "📝 Running ESLint on staged files..."
if [ -n "$STAGED_FILES" ]; then
  ESLINT_FILES=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx|js|jsx)$' || true)
  if [ -n "$ESLINT_FILES" ]; then
    echo "$ESLINT_FILES" | xargs npx eslint --no-warn-ignored
    if [ $? -ne 0 ]; then
      echo "❌ ESLint failed on staged files. Fix errors before committing."
      exit 1
    fi
  fi
else
  echo "No staged files to check."
fi
echo "✅ ESLint passed"
echo ""

# 2. TypeScript Check (runs on full project, needed for type safety)
echo "🔎 Running TypeScript check..."
npm run type-check
if [ $? -ne 0 ]; then
  echo "❌ TypeScript check failed. Fix errors before committing."
  exit 1
fi
echo "✅ TypeScript check passed"
echo ""

echo "🎉 All pre-commit checks passed!"
