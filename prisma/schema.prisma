generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Lead / Contact ──────────────────────────────────────────────────────────
model Contact {
  id                      String   @id @default(cuid())
  fullName                String
  email                   String
  phone                   String?
  company                 String?
  projectType             String
  budget                  String?
  timeline                String?
  website                 String?
  startDate               String?
  projectDetails          String
  projectGoals            String?
  hasExistingWebsite      Boolean?
  existingWebsiteUrl      String?
  preferredContactMethod  String?
  communicationMethod     String?
  referralSource          String?
  fileName                String?
  fileUrl                 String?
  leadScore               Int      @default(0)
  status                  String   @default("NEW")
  notes                   String?
  tags                    String?
  assignedTo              String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  events                  LeadTimeline[]
  appointments            Appointment[]

  @@map("contacts")
}

model LeadTimeline {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  action    String
  detail    String?
  createdAt DateTime @default(now())

  @@map("lead_timeline")
}

// ─── Clients ─────────────────────────────────────────────────────────────────
model Client {
  id        String         @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  website   String?
  notes     String?
  avatar    String?
  status    String         @default("ACTIVE")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  projects  Project[]
  appointments Appointment[]

  @@map("clients")
}

// ─── Projects ────────────────────────────────────────────────────────────────
model Project {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  budget      Float?
  deadline    DateTime?
  status      String     @default("PLANNING")
  priority    String     @default("MEDIUM")
  clientId    String?
  client      Client?    @relation(fields: [clientId], references: [id])
  tags        String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  milestones  Milestone[]
  tasks       Task[]
  appointments Appointment[]

  @@map("projects")
}

model Milestone {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  dueDate     DateTime?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  @@map("milestones")
}

model Task {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  assignee    String?
  status      String   @default("TODO")
  priority    String   @default("MEDIUM")
  dueDate     DateTime?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tasks")
}

// ─── Portfolio ───────────────────────────────────────────────────────────────

model PortfolioCategory {
  id          String             @id @default(cuid())
  name        String
  slug        String             @unique
  description String?
  icon        String?
  order       Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  projects    PortfolioProject[]

  @@index([order])
  @@map("portfolio_categories")
}

model Technology {
  id        String             @id @default(cuid())
  name      String
  slug      String             @unique
  icon      String?
  color     String?
  category  String?            // frontend, backend, database, devops, mobile, other
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  projects  PortfolioProject[]

  @@index([category])
  @@map("technologies")
}

model PortfolioProject {
  id                String            @id @default(cuid())
  title             String
  slug              String            @unique
  shortDescription  String?
  fullDescription   String?
  projectSummary    String?
  clientName        String?
  clientIndustry    String?
  categoryId        String?
  category          PortfolioCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  technologies      Technology[]
  featuredImage     String?
  thumbnailImage    String?
  galleryImages     Json              @default("[]")
  videoDemo         String?
  projectLogo       String?
  startDate         DateTime?
  completionDate    DateTime?
  projectDuration   String?
  teamSize          Int?
  status            String            @default("DRAFT") // DRAFT, IN_PROGRESS, COMPLETED, ARCHIVED
  featured          Boolean           @default(false)
  published         Boolean           @default(false)
  order             Int               @default(0)
  viewCount         Int               @default(0)
  liveUrl           String?
  githubUrl         String?
  demoUrl           String?
  caseStudyUrl      String?
  metaTitle         String?
  metaDescription   String?
  ogImage           String?
  canonicalUrl      String?
  tags              Json              @default("[]")
  awards            Json              @default("[]")
  testimonialIds    Json              @default("[]")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  caseStudy         CaseStudy?
  metrics           ProjectMetric[]
  dailyViews        ProjectDailyView[]
  resumeFeatured    ResumeFeaturedProject[]
  clientId          String?
  client            CrmClient? @relation("ClientProjects", fields: [clientId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([status])
  @@index([featured])
  @@index([order])
  @@index([createdAt])
  @@map("portfolio_projects")
}

model ProjectMetric {
  id          String           @id @default(cuid())
  projectId   String
  project     PortfolioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label       String
  value       String
  prefix      String?
  suffix      String?
  order       Int              @default(0)
  createdAt   DateTime         @default(now())

  @@index([projectId])
  @@map("project_metrics")
}

model ProjectDailyView {
  id        String           @id @default(cuid())
  projectId String
  project   PortfolioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  date      DateTime         @db.Date
  count     Int              @default(1)

  @@unique([projectId, date])
  @@index([projectId])
  @@index([date])
  @@map("project_daily_views")
}

model CaseStudy {
  id                  String           @id @default(cuid())
  projectId           String           @unique
  project             PortfolioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clientBackground    String?
  businessProblem     String?
  objectives          String?
  research            String?
  solution            String?
  developmentProcess  String?
  results             String?
  lessonsLearned      String?
  challenges          String?
  requirements        String?
  projectGoals        String?
  problemStatement    String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@map("case_studies")
}

// ─── Blog ────────────────────────────────────────────────────────────────────
model BlogPost {
  id              String         @id @default(cuid())
  title           String
  slug            String         @unique
  excerpt         String?
  content         String         @default("")
  image           String?
  category        String?
  tags            String?
  author          String         @default("Emmett Anthony")
  published       Boolean        @default(false)
  featured        Boolean        @default(false)
  publishedAt     DateTime?
  scheduledAt     DateTime?
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  readingTime     Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  revisions       BlogRevision[]

  @@map("blog_posts")
}

model BlogRevision {
  id              String   @id @default(cuid())
  postId          String
  post            BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  title           String
  content         String
  excerpt         String?
  category        String?
  tags            String?
  image           String?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())

  @@index([postId, createdAt])
  @@map("blog_revisions")
}



// ─── Testimonials ────────────────────────────────────────────────────────────
model Testimonial {
  id              String   @id @default(cuid())
  name            String
  jobTitle        String?
  company         String?
  companyWebsite  String?
  email           String?
  photo           String?
  companyLogo     String?
  title           String?
  content         String
  rating          Int      @default(5)
  projectName     String?
  projectCategory String?
  category        String?
  status          String   @default("PENDING")
  featured        Boolean  @default(false)
  displayOnHomepage Boolean @default(true)
  archived        Boolean  @default(false)
  order           Int      @default(0)
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  submittedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([featured])
  @@index([createdAt])
  @@map("testimonials")
}

model TestimonialCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())

  @@map("testimonial_categories")
}

// ─── Newsletter System ───────────────────────────────────────────────────────

model Subscriber {
  id                String           @id @default(cuid())
  firstName         String
  lastName          String
  email             String           @unique
  phone             String?
  company           String?
  country           String?
  tags              String?          // JSON array of tag IDs
  source            String?          // footer, blog_sidebar, contact_page, popup, exit_intent, manual_import
  status            SubscriberStatus @default(ACTIVE)
  verificationToken String?
  verifiedAt        DateTime?
  gdprConsent       Boolean          @default(false)
  subscribedAt      DateTime         @default(now())
  lastOpenedAt      DateTime?
  lastClickedAt     DateTime?
  timezone          String?          // e.g. "America/New_York", "Europe/London"
  notes             String?
  engagementScore   Int              @default(0) // 0-100 computed score
  metadata          Json?            // Flexible extra data
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  emailLogs         EmailLog[]
  campaignEvents    CampaignEvent[]
  customFieldValues CustomFieldValue[]
  preferences       SubscriberPreference?
  unsubscribeReason UnsubscribeReason?

  @@index([email])
  @@index([status])
  @@index([source])
  @@index([country])
  @@index([createdAt])
  @@map("subscribers")
}

enum SubscriberStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
  PENDING_VERIFICATION
}

model SubscriberPreference {
  id                     String     @id @default(cuid())
  subscriberId           String     @unique
  subscriber             Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  topics                 String?    // JSON array of topic IDs
  emailFrequency         String     @default("instant") // instant, daily, weekly, monthly
  preferredSendHour      Int        @default(9)          // 0-23, local time hour to send emails
  receivePromotions      Boolean    @default(true)
  receiveNewsletters     Boolean    @default(true)
  receiveBlogUpdates     Boolean    @default(true)
  updatedAt              DateTime   @updatedAt

  @@map("subscriber_preferences")
}

model UnsubscribeReason {
  id             String     @id @default(cuid())
  subscriberId   String     @unique
  subscriber     Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  reason         String?
  detail         String?
  unsubscribedAt DateTime   @default(now())

  @@map("unsubscribe_reasons")
}

model Tag {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  color       String    @default("#3b82f6")
  description String?
  createdAt   DateTime  @default(now())
  segments    Segment[]

  @@map("tags")
}

model Segment {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  criteria    Json?      // Flexible segment criteria (country, tags, source, activity, etc.)
  isDynamic   Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tags        Tag[]
  campaigns   Campaign[]

  @@map("segments")
}

// ─── Campaigns ───────────────────────────────────────────────────────────────

model Campaign {
  id              String          @id @default(cuid())
  name            String
  subject         String
  previewText     String?
  senderName      String?
  senderEmail     String?
  content         String          @default("")
  status          String          @default("DRAFT") // DRAFT, REVIEW, APPROVED, SCHEDULED, SENDING, AWAITING_WINNER, SENT, PAUSED, CANCELLED, FAILED
  submittedForReviewAt DateTime?
  approvedAt          DateTime?
  reviewNotes         String?
  templateId      String?
  template        Template?       @relation(fields: [templateId], references: [id])
  segmentId       String?
  segment         Segment?        @relation(fields: [segmentId], references: [id])
  scheduledAt     DateTime?
  sentAt          DateTime?
  completedAt     DateTime?
  totalRecipients Int             @default(0)
  testEmails      String?         // JSON array of test email addresses
  abTestEnabled       Boolean         @default(false)
  abTestVariantA      String?         // JSON for variant A
  abTestVariantB      String?         // JSON for variant B
  abTestTestPercent   Int             @default(20)  // % of list to test on before winner promotion
  abTestWinner        String?         // "A" or "B" when winner is declared
  abTestWinnerDeclaredAt DateTime?
  isPublic            Boolean         @default(false)
  recurringFrequency  String?         // "daily", "weekly", "monthly", null for one-time
  recurringDayOfWeek  Int?            // 0=Sun..6=Sat for weekly
  recurringDayOfMonth Int?            // 1-31 for monthly
  recurringNextRunAt  DateTime?
  recurringEndsAt     DateTime?       // optional end date
  recurringCount      Int             @default(0) // how many times sent
  recurringMaxCount   Int?            // optional max sends
  metadata            Json?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  events          CampaignEvent[]
  emailLogs       EmailLog[]
  automations     Automation[]

  @@index([status])
  @@index([createdAt])
  @@map("campaigns")
}

model CampaignEvent {
  id                String    @id @default(cuid())
  campaignId        String
  campaign          Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  subscriberId      String?
  subscriber        Subscriber? @relation(fields: [subscriberId], references: [id], onDelete: SetNull)
  email             String
  eventType         String    // sent, opened, clicked, bounced, unsubscribed, complained
  metadata          Json?     // click URL, user agent, ip, etc.
  createdAt         DateTime  @default(now())

  @@index([campaignId, eventType])
  @@index([subscriberId])
  @@index([createdAt])
  @@map("campaign_events")
}

model EmailLog {
  id             String    @id @default(cuid())
  campaignId     String?
  campaign       Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  subscriberId   String?
  subscriber     Subscriber? @relation(fields: [subscriberId], references: [id], onDelete: SetNull)
  email          String
  subject        String?
  status         String    // queued, sent, delivered, bounced, failed, opened, clicked
  error          String?
  sentAt         DateTime?
  openedAt       DateTime?
  clickedAt      DateTime?
  opensCount     Int       @default(0)
  clicksCount    Int       @default(0)
  resendId       String?   // Resend API message ID
  metadata       Json?
  createdAt      DateTime  @default(now())

  @@index([campaignId])
  @@index([subscriberId])
  @@index([status])
  @@map("email_logs")
}

// ─── Templates ───────────────────────────────────────────────────────────────

model Template {
  id          String     @id @default(cuid())
  name        String
  description String?
  content     String     @default("")
  category    String?    // company_newsletter, product_update, blog_digest, announcement, promotion, event, custom
  thumbnail   String?
  isBuiltIn   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  campaigns   Campaign[]

  @@index([category])
  @@map("templates")
}

// ─── Automations ─────────────────────────────────────────────────────────────

model Automation {
  id             String            @id @default(cuid())
  name           String
  description    String?
  triggerType    String            // welcome_series, blog_notification, lead_nurturing, re_engagement, tag_added, custom
  triggerConfig  Json?             // Trigger configuration (delay, conditions, etc.)
  status         String            @default("ACTIVE") // ACTIVE, PAUSED, ARCHIVED
  campaignId     String?
  campaign       Campaign?         @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  steps          AutomationStep[]  // For multi-step automations

  @@index([triggerType, status])
  @@map("automations")
}

model AutomationStep {
  id            String     @id @default(cuid())
  automationId  String
  automation    Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  stepOrder     Int
  name          String
  subject       String?
  content       String?
  delayDays     Int        @default(0)
  delayHours    Int        @default(0)
  condition     Json?      // Optional condition for conditional branching
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([automationId, stepOrder])
  @@map("automation_steps")
}

// ─── Calendar System ──────────────────────────────────────────────────────────

// ─── Meeting Types ────────────────────────────────────────────────────────────
model MeetingType {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  duration    Int      @default(30)  // in minutes
  color       String   @default("#3b82f6")  // hex color for calendar
  icon        String?  // lucide icon name
  location    String?  // "virtual", "in-person", or custom
  link        String?  // default meeting link (e.g., Google Meet, Zoom)
  price       Float?   // if paid consultation
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  events      CalendarEvent[]
  appointments Appointment[]

  @@index([slug])
  @@index([isActive])
  @@map("meeting_types")
}

// ─── Appointments (extended) ──────────────────────────────────────────────────
model Appointment {
  id            String       @id @default(cuid())
  name          String
  email         String
  phone         String?
  company       String?
  projectType   String?
  preferredDate DateTime
  preferredTime String?      // stored as "HH:mm"
  duration      Int          @default(30)
  message       String?
  notes         String?      // internal notes
  status        String       @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED, RESCHEDULED, NO_SHOW
  source        String       @default("WEBSITE") // WEBSITE, DASHBOARD, REFERRAL, OTHER
  timezone      String?
  website       String?
  country       String?
  budget        String?
  timeline      String?
  preferredContactMethod String?
  newsletter    Boolean   @default(false)
  terms         Boolean   @default(false)
  fileUrl       String?
  fileName      String?
  meetingTypeId String?
  meetingType   MeetingType? @relation(fields: [meetingTypeId], references: [id], onDelete: SetNull)
  contactId     String?      // link to CRM lead
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  projectId     String?      // link to project
  project       Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  clientId      String?      // link to client
  client        Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  cancellationReason String?
  rescheduleCount Int       @default(0)
  reminderSent   Boolean    @default(false)
  confirmedAt    DateTime?
  cancelledAt    DateTime?
  completedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  events         CalendarEvent[]
  appointmentLogs AppointmentLog[]

  @@index([email])
  @@index([status])
  @@index([preferredDate])
  @@index([meetingTypeId])
  @@index([contactId])
  @@map("appointments")
}

// ─── Calendar Events ──────────────────────────────────────────────────────────
model CalendarEvent {
  id            String       @id @default(cuid())
  title         String
  description   String?
  startDate     DateTime
  endDate       DateTime?
  startTime     String?      // "HH:mm"
  endTime       String?      // "HH:mm"
  allDay        Boolean      @default(false)
  location      String?
  link          String?      // meeting link
  color         String       @default("#3b82f6")  // hex color
  eventType     String       @default("MEETING") // MEETING, CONSULTATION, PROJECT_DEADLINE, PERSONAL, TASK, REMINDER
  status        String       @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED, RESCHEDULED
  priority      String       @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  notes         String?
  attachments   String?      // JSON array of file URLs
  recurring     String?      // JSON for recurring rule: { freq: "daily"|"weekly"|"monthly"|"yearly", interval: 1, until: "date", count: 5 }
  recurrenceId  String?      // group ID for recurring event instances
  metadata      Json?        // flexible extra data
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  meetingTypeId String?
  meetingType   MeetingType? @relation(fields: [meetingTypeId], references: [id], onDelete: SetNull)
  taskId        String?
  task          CalendarTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  reminderId    String?
  reminder      Reminder?    @relation(fields: [reminderId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([startDate])
  @@index([endDate])
  @@index([eventType])
  @@index([status])
  @@index([appointmentId])
  @@index([taskId])
  @@index([reminderId])
  @@map("calendar_events")
}

// ─── Calendar Tasks ───────────────────────────────────────────────────────────
model CalendarTask {
  id          String         @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  priority    String         @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status      String         @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  progress    Int            @default(0) // 0-100
  category    String?        // work, personal, follow-up, etc.
  tags        String?        // JSON array
  order       Int            @default(0)
  color       String         @default("#8b5cf6")
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  events      CalendarEvent[]

  @@index([status])
  @@index([dueDate])
  @@index([priority])
  @@map("calendar_tasks")
}

// ─── Reminders ────────────────────────────────────────────────────────────────
model Reminder {
  id              String         @id @default(cuid())
  title           String
  description     String?
  remindAt        DateTime
  remindType      String         @default("EMAIL") // EMAIL, DASHBOARD, BOTH
  status          String         @default("PENDING") // PENDING, SENT, DISMISSED
  sentAt          DateTime?
  relatedType     String?        // MEETING, DEADLINE, TASK, FOLLOW_UP
  relatedId       String?        // ID of the related entity
  repeatInterval  String?        // "daily", "weekly", "monthly", "yearly"
  repeatUntil     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  events          CalendarEvent[]

  @@index([remindAt])
  @@index([status])
  @@index([relatedType, relatedId])
  @@map("reminders")
}

// ─── Availability / Working Hours ─────────────────────────────────────────────
model Availability {
  id        String   @id @default(cuid())
  dayOfWeek Int      // 0=Sunday, 1=Monday, ..., 6=Saturday
  isActive  Boolean  @default(true)
  startTime String   // "HH:mm"
  endTime   String   // "HH:mm"
  breakStart String? // "HH:mm"
  breakEnd   String? // "HH:mm"
  slotDuration Int   @default(30) // minutes per time slot
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dayOfWeek])
  @@index([dayOfWeek, isActive])
  @@map("availability")
}

// ─── Date Exceptions (holidays, vacations, blocked dates) ─────────────────────
model DateException {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  type        String   // HOLIDAY, VACATION, BLOCKED, SPECIAL_HOURS
  title       String?
  isAvailable Boolean  @default(false)
  startTime   String?  // for special hours
  endTime     String?  // for special hours
  description String?
  createdAt   DateTime @default(now())

  @@unique([date, type])
  @@index([date])
  @@map("date_exceptions")
}

// ─── Calendar Integrations ────────────────────────────────────────────────────
model CalendarIntegration {
  id            String   @id @default(cuid())
  provider      String   // GOOGLE, OUTLOOK, APPLE
  email         String?
