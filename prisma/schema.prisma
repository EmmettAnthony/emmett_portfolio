enum ActivitySeverity {
  INFO
  WARNING
  ERROR
  CRITICAL

  @@map("activity_severity")
}

model ActivityLog {
  id          String           @id @default(cuid())
  userId      String?
  user        User?            @relation(fields: [userId], references: [id])
  action      String           // e.g., "login", "create", "update", "delete", "publish", "archive"
  module      String           // e.g., "auth", "crm", "contact", "portfolio", "blog", "newsletter", "calendar", "payment", "file", "user", "system"
  entity      String?          // e.g., "Lead", "Client", "Project", "BlogPost"
  entityId    String?          // ID of the affected entity
  description String           // Human-readable description
  severity    ActivitySeverity @default(INFO)
  metadata    Json?            // Flexible extra data
  ip          String?
  userAgent   String?
  browser     String?          // Extracted browser name
  os          String?          // Extracted OS name
  device      String?          // Extracted device type
  country     String?          // Geo-location (future)
  createdAt   DateTime         @default(now())

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([entity, entityId])
  @@index([severity])
  @@index([createdAt])
  @@index([module, action])
  @@map("activity_logs")
}

model AuditTrail {
  id          String   @id @default(cuid())
  entityType  String   // e.g., "Lead", "Client", "Project", "BlogPost"
  entityId    String   // ID of the audited entity
  action      String   // "create", "update", "delete"
  field       String?  // which field changed (null for create/delete)
  beforeValue String?  // previous value (for updates)
  afterValue  String?  // new value (for updates)
  beforeData  Json?    // Full snapshot before change
  afterData   Json?    // Full snapshot after change
  userId      String?
  description String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([entityType])
  @@index([entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_trails")
}

model SecurityEvent {
