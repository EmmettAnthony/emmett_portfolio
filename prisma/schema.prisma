// ─── Notifications ───────────────────────────────────────────────────────────
// Enterprise Notification System
// Categories: CRM, CONTACT, CALENDAR, PORTFOLIO, NEWSLETTER, RESUME, TESTIMONIAL, SYSTEM

enum NotifCategory {
  CRM
  CONTACT
  CALENDAR
  PORTFOLIO
  NEWSLETTER
  RESUME
  TESTIMONIAL
  SUPPORT
  SYSTEM

  @@map("notif_category")
}

enum NotifPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@map("notif_priority")
}

enum NotifType {
  INFO
  SUCCESS
  WARNING
  ERROR

  @@map("notif_type")
}

enum NotifDeliveryChannel {
  IN_APP
  EMAIL
  PUSH
  SMS
  WHATSAPP

  @@map("notif_delivery_channel")
}

model Notification {
  id              String     @id @default(cuid())
  userId          String?    // null = system-wide notification
  category        NotifCategory @default(SYSTEM)
  priority        NotifPriority @default(MEDIUM)
  notifType       NotifType     @default(INFO) @map("notif_type")
  key             String?    // unique key for deduplication (e.g., "lead-new-{id}")
  title           String
  message         String?
  link            String?    // relative URL to navigate to
  image           String?    // optional notification image/avatar URL
  read            Boolean    @default(false)
  archived        Boolean    @default(false)
  pinned          Boolean    @default(false)
  snoozedUntil    DateTime?
  acknowledged    Boolean    @default(false) // critical requires acknowledgement
  actionLabel     String?    // e.g., "View Deal", "Reply", "Approve"
  actionUrl       String?    // URL for the action button
  metadata        Json?      // flexible extra data (related entity ids, etc.)
  source          String?    // which module created this (crm, calendar, newsletter, etc.)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  sentAt          DateTime?  // when it was delivered (for scheduled)
  expiresAt       DateTime?  // auto-archive after this date
  logs            NotificationLog[]

  @@index([userId, read])
  @@index([userId, category])
  @@index([userId, priority])
  @@index([category])
  @@index([priority])
  @@index([key])
  @@index([createdAt])
  @@index([expiresAt])
  @@map("notifications")
}

model NotificationPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  // Per-category delivery channel preferences (JSON)
  // Format: { "CRM": ["IN_APP","EMAIL"], "NEWSLETTER": ["IN_APP"], ... }
  categoryChannels Json     @default("{}")
  // Global settings
  emailDigest      String   @default("instant") // instant, daily, weekly, never
  pushEnabled      Boolean  @default(false)
  soundEnabled     Boolean  @default(true)
  desktopEnabled   Boolean  @default(false)
  quietHoursStart  String?  // "HH:mm"
  quietHoursEnd    String?  // "HH:mm"
  snoozeUntil      DateTime? // global snooze
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("notification_preferences")
}

model NotificationTemplate {
  id              String   @id @default(cuid())
  name            String   @unique
  label           String
  category        NotifCategory @default(SYSTEM)
  priority        NotifPriority @default(MEDIUM)
  notifType       NotifType     @default(INFO) @map("notif_type")
  title           String   // supports {{variable}} placeholders
  message         String?  // supports {{variable}} placeholders
  emailSubject    String?  // for email delivery
  emailBody       String?  // HTML template for email
  pushTitle       String?  // for push notification
  pushBody        String?  // for push notification
  variables       Json     @default("[]") // array of variable names this template uses
  channels        Json     @default("[\"IN_APP\"]") // default delivery channels
  actionLabel     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@map("notification_templates")
}

model NotificationLog {
  id              String       @id @default(cuid())
  notificationId  String
  notification    Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  channel         NotifDeliveryChannel
  status          String       // queued, sent, delivered, failed, opened, clicked
  error           String?
  sentAt          DateTime?
  deliveredAt     DateTime?
  openedAt        DateTime?
  clickedAt       DateTime?
  metadata        Json?        // provider-specific data (e.g., Resend message ID)
  createdAt       DateTime     @default(now())

  @@index([notificationId])
  @@index([channel, status])
  @@index([createdAt])
  @@map("notification_logs")
}

// ─── Analytics (kept simple, extended from existing) ─────────────────────────
