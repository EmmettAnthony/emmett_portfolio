# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Required for the contact form, newsletter, analytics, and lead management.
# Get a free PostgreSQL database from Neon, Vercel Postgres, or Supabase.
DATABASE_URL=postgresql://user:password@host:5432/dbname
DIRECT_URL=postgresql://user:password@host:5432/dbname

# ── Booking Platforms ──────────────────────────────────────────────────────────
# Optional. These add booking options to the /book page.
# Google Calendar appointment scheduling page:
# NEXT_PUBLIC_GOOGLE_CALENDAR_URL=
# Calendly scheduling page (opens in native popup widget):
# NEXT_PUBLIC_CALENDLY_URL=
# Microsoft Teams / Bookings scheduling URL:
# NEXT_PUBLIC_TEAMS_BOOKING_URL=

# ── Resend (Contact Form Email) ───────────────────────────────────────────────
# Required for the contact form to send emails. Get your API key at:
# https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_RESEND_API_KEY

# Email address used as the sender for contact form messages.
# Must be verified in your Resend dashboard.
SENDER_EMAIL=your-email@example.com

# If SENDER_EMAIL is set to a Gmail address (which Resend doesn't support),
# or if SENDER_EMAIL is not set, the system falls back to:
#   noreply@RESEND_DEFAULT_DOMAIN  (if set)
#   delivered@resend.dev           (otherwise)
# RESEND_DEFAULT_DOMAIN=emmettanthony.dev

# ── Cloudflare Turnstile (Bot Protection) ─────────────────────────────────────
# Required for bot protection on the contact form.
# Get your site key and secret key at: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# ── Admin Dashboard ───────────────────────────────────────────────────────────
# Required for the admin lead management dashboard.
# AUTH_SECRET is generated by running: npx auth secret
AUTH_SECRET=

# CRON_SECRET - used to authenticate Vercel Cron Jobs calling /api/newsletter/cron
# Set this to a random string and configure it as the Authorization Bearer token in your Vercel Cron config
CRON_SECRET=

ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here

# ── Google Calendar Integration ───────────────────────────────────────────────
# Optional. Required for the "Book a Free Consultation" feature.
# For the booking system: create a service account at https://console.cloud.google.com/apis/credentials
# and paste the full JSON key here (minified, single line).
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# OAuth2 credentials (used by the dashboard calendar sync, not the booking system).
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=162942769546-hlbt9vmn6b8787qjouahu3v574d4lct0
GOOGLE_CLIENT_SECRET=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

# ── Outlook Calendar Integration ──────────────────────────────────────────────
# Optional. Sync events with Microsoft Outlook Calendar.
# Register an app at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
# Requires API permissions: Calendars.ReadWrite, offline_access, User.Read
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=

# ── Google Analytics & Tag Manager ────────────────────────────────────────────
# Optional. Set NEXT_PUBLIC_GA_ID for Google Analytics 4 or
# NEXT_PUBLIC_GTM_ID for Google Tag Manager.
NEXT_PUBLIC_SITE_URL=https://emmettanthony.dev
# NEXT_PUBLIC_BASE_URL is used as the base URL for email tracking links.
# Falls back to https://emmettanthony.dev if not set.
# NEXT_PUBLIC_BASE_URL=https://emmettanthony.dev
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ── UploadThing (File Uploads) ────────────────────────────────────────────────
# Required for image uploads throughout the application.
# Get your keys at: https://uploadthing.com/dashboard
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# ── Sentry Error Tracking ────────────────────────────────────────────────────
# Required for production error monitoring.
# Get your DSN at: https://sentry.io/settings/projects/
SENTRY_DSN=https://your-dsn@your-org.ingest.sentry.io/
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@your-org.ingest.sentry.io/

# ── Upstash Redis (Rate Limiting + Caching) ──────────────────────────────────
# Optional but highly recommended for production rate limiting.
# Get these from the Vercel Marketplace (Upstash Redis integration).
# Falls back to in-memory rate limiting if not set.
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ── AI Chatbot Provider API Keys ──────────────────────────────────────────────
# Required for the AI chatbot. At least one provider API key must be set.
# OpenAI is the default provider and is also used for embeddings/RAG search.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# GROQ_API_KEY=

# ── Brevo (Email Marketing) ──────────────────────────────────────────────────
# Required for newsletter email marketing features (contact sync, campaigns,
# transactional email). Get your API key at: https://app.brevo.com/api/key
# Optionally set EMAIL_PROVIDER=brevo to send newsletter campaigns via Brevo
# instead of Resend (default).
BREVO_API_KEY=xkeysib-your_brevo_api_key
# EMAIL_PROVIDER=brevo

# ── Bundle Analysis ───────────────────────────────────────────────────────────
# Optional. Set to "true" to run the Next.js bundle analyzer during build.
# ANALYZE=true
