// ─── Internationalization (i18n) ────────────────────────────────────────────

enum LanguageDirection {
  LTR
  RTL

  @@map("lang_direction")
}

model SiteLanguage {
  id            String            @id @default(cuid())
  code          String            @unique // ISO 639-1: en, fr, es, pt, ar, de, it, zh, ja, ko
  name          String            // Native name: English, Français, Español
  nameEn        String            // English name: English, French, Spanish
  nativeName    String            // Self-name in its own script: English, Français, Español, العربية
  direction     LanguageDirection @default(LTR)
  flagEmoji     String?           // 🇺🇸, 🇫🇷, 🇪🇸, etc.
  flagImage     String?           // URL to custom flag image
  isEnabled     Boolean           @default(true)
  isDefault     Boolean           @default(false)
  fallbackLocale String?          // Fallback language code for missing translations
  order         Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  groups        TranslationGroup[]
  translations  Translation[]

  @@index([isEnabled])
  @@index([order])
  @@index([code])
  @@map("site_languages")
}

model TranslationGroup {
  id          String        @id @default(cuid())
  name        String        // e.g., "Homepage", "Navigation", "Footer"
  slug        String        @unique // e.g., "homepage", "navigation", "footer"
  description String?
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  languageId  String?
  language    SiteLanguage?     @relation(fields: [languageId], references: [id], onDelete: Cascade)
  translations Translation[]

  @@index([slug])
  @@index([order])
  @@map("translation_groups")
}

model Translation {
  id          String           @id @default(cuid())
  groupId     String
  group       TranslationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  key         String           // e.g., "hero.title", "nav.home"
  value       String?          // Translated text (null = missing)
  languageId  String
  language    SiteLanguage     @relation(fields: [languageId], references: [id], onDelete: Cascade)
  pluralForm  String?          // "zero", "one", "two", "few", "many", "other" (for ICU MessageFormat)
  context     String?          // Optional context hint for translators
  isAutoTranslated Boolean     @default(false)
  needsReview  Boolean         @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([groupId, key, languageId])
  @@index([groupId])
  @@index([languageId])
  @@index([key])
  @@map("translations")
}

model LocaleSetting {
  id              String   @id @default("global")
  autoDetect      Boolean  @default(true)
  localePrefix    String   @default("always") // "always" | "as-needed" | "never"
  cookieName      String   @default("NEXT_LOCALE")
  enableTranslationApi Boolean @default(false)
  translationApiProvider String? // "google", "deepl", "openai", "azure"
  translationApiKey     String?
  updatedAt       DateTime @updatedAt

  @@map("locale_settings")
}

