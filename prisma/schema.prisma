  blockedWords            String[] @default([])
  rateLimitPerMinute      Int      @default(10)
  rateLimitPerDay         Int      @default(500)
  maxConversationLength   Int      @default(100)
  enableFileSearch        Boolean  @default(true)
  enableLeadCapture       Boolean  @default(true)
  enableBooking           Boolean  @default(true)
  enableHumanHandoff      Boolean  @default(true)
  enableMultilingual      Boolean  @default(true)
  enableAnalytics         Boolean  @default(true)
  enableWelcomeTrigger    Boolean  @default(true)
  welcomeDelayMs          Int      @default(15000)
  enableExitIntent        Boolean  @default(true)
  exitIntentMessage       String   @default("👋 Before you go! I'd love to help with your next project. Whether you need a website, web app, CRM, or just have a question — I'm here to chat. What's on your mind?")
  widgetPosition          String   @default("right")
  widgetColor             String   @default("#2563eb")
  widgetTitle             String   @default("Chat with Emmett")
  widgetSubtitle          String   @default("AI Assistant")
  widgetAvatar            String?
  widgetSize              String   @default("md")
  enabled                 Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("chat_settings")
}

model ChatFeedback {
  id              String           @id @default(cuid())
  conversationId  String           @unique
  conversation    ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  score           Int
  comment         String?
  category        String?
  createdAt       DateTime         @default(now())

  @@map("chat_feedback")
}

model ChatAnalytics {
  id                String   @id @default(cuid())
  date              DateTime @unique
  totalConversations Int     @default(0)
  totalMessages     Int      @default(0)
  leadsGenerated    Int      @default(0)
  bookingsMade      Int      @default(0)
  questionsAsked    Int      @default(0)
  resolvedCount     Int      @default(0)
  escalatedCount    Int      @default(0)
  avgResponseTime       Float    @default(0)
  avgSessionDuration    Float    @default(0)
  satisfactionScore     Float    @default(0)
  welcomeTriggerCount   Int      @default(0)
  exitIntentTriggerCount Int     @default(0)
  popularTopics         Json     @default("{}")
  providerUsage         Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("chat_analytics")
}

// ═══════════════════════════════════════════════════════════════════════════
// BREVO EMAIL MODULE
// ═══════════════════════════════════════════════════════════════════════════

model EmailSetting {
  id                String   @id @default("global")
  apiKey            String?
  smtpServer        String   @default("smtp-relay.brevo.com")
  smtpPort          Int      @default(587)
  smtpLogin         String?
  smtpPassword      String?
  senderName        String   @default("Emmett Anthony")
  senderEmail       String?
  replyToEmail      String?
  trackingEnabled   Boolean  @default(true)
  doubleOptIn       Boolean  @default(true)
  defaultListId     String?
  dailySendLimit    Int      @default(300)
  weeklySendLimit   Int      @default(2000)
  monthlySendLimit  Int      @default(8000)
  webhookSecret     String?
  lastSyncAt        DateTime?
  updatedAt         DateTime @updatedAt

  @@map("email_settings")
}

model ContactList {
  id          String              @id @default(cuid())
  name        String
  description String?
  brevoId     Int?                @unique // Brevo's list ID
  folderId    Int?
  isDefault   Boolean             @default(false)
  isPublic    Boolean             @default(true)
  isArchived  Boolean             @default(false)
  subscriberCount Int             @default(0)
  source      String?             // newsletter, clients, leads, partners, manual
  color       String?             @default("#3b82f6")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  members     ContactListMember[]

  @@index([isDefault])
  @@index([isArchived])
  @@index([source])
  @@map("contact_lists")
}

model ContactListMember {
  id              String      @id @default(cuid())
  listId          String
  list            ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)
  email           String
  firstName       String?
  lastName        String?
  company         String?
  phone           String?
  website         String?
  country         String?
  tags            String?     // JSON array
  source          String?     // contact_form, booking, crm, newsletter, payment, chatbot, manual
  status          String      @default("ACTIVE") // ACTIVE, UNSUBSCRIBED, BOUNCED, PENDING
  metadata        Json?
  brevoContactId  Int?        // Brevo's contact ID
  brevoSyncStatus String      @default("PENDING") // PENDING, SYNCED, FAILED
  brevoSyncError  String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([listId, email])
  @@index([listId])
  @@index([email])
  @@index([status])
  @@index([brevoSyncStatus])
  @@map("contact_list_members")
}

model BrevoSyncLog {
  id          String   @id @default(cuid())
  action      String   // contact_create, contact_update, contact_delete, list_create, campaign_send, template_sync, webhook_received
  entityType  String?  // contact, list, campaign, template
  entityId    String?  // local entity ID
  brevoId     String?  // Brevo entity ID
  status      String   // SUCCESS, FAILED, PENDING
  request     Json?
  response    Json?
  error       String?
  duration    Int?     // ms
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([status])
  @@index([createdAt])
  @@map("brevo_sync_logs")
}

// ─── Support System ─────────────────────────────────────────────────────────

model SupportAutomationRule {
  id          String   @id @default(cuid())
  name        String   @unique
  trigger     String   // "ticket_created", "ticket_updated", "ticket_closed", "ticket_escalated"
  conditions  Json     // Array of { field: string; operator: "equals" | "contains" | "gt" | "lt"; value: string }
  actions     Json     // Array of { type: "assign_to" | "change_status" | "change_priority" | "add_tag" | "send_email" | "notify"; value: string }
  isEnabled   Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("support_automation_rules")
}

model SupportTicketTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  fields      Json     // Array of { name: string; label: string; type: "text" | "textarea" | "select" | "email" | "tel"; required: boolean; options?: string[] }
  defaultPriorityId String?
  defaultPriority   SupportPriority? @relation(fields: [defaultPriorityId], references: [id])
  defaultCategoryId String?
  defaultCategory   SupportCategory? @relation(fields: [defaultCategoryId], references: [id])
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("support_ticket_templates")
}

model SupportCategory {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String?
  icon        String?
  color       String?
  order       Int            @default(0)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  tickets     SupportTicket[]
  ticketTemplates SupportTicketTemplate[]

  @@index([order])
  @@index([isActive])
  @@map("support_categories")
}

model SupportPriority {
  id        String         @id @default(cuid())
  name      String         @unique
  slug      String         @unique
  level     Int            @default(0)
  color     String?
  slaHours  Int?           // Target response time in hours
  createdAt DateTime       @default(now())
  tickets   SupportTicket[]
  ticketTemplates SupportTicketTemplate[]

  @@index([level])
  @@map("support_priorities")
}

model SupportStatus {
  id        String         @id @default(cuid())
  name      String         @unique
  slug      String         @unique
  color     String?
  order     Int            @default(0)
  isClosed  Boolean        @default(false)
  isDefault Boolean        @default(false)
  createdAt DateTime       @default(now())
  tickets   SupportTicket[]

  @@index([order])
  @@map("support_statuses")
}

model SupportTicket {
  id                  String            @id @default(cuid())
  ticketNumber        String            @unique
  subject             String
  description         String
  fullName            String
  email               String
  phone               String?
  company             String?
  preferredContact    String?           // email, phone, any
  source              String            @default("web") // web, email, chatbot, api, phone
  tags                String?           // JSON array
  internalNotes       String?
  responseTime        Int?              // Minutes to first response
  resolutionTime      Int?              // Minutes to resolution
  firstResponseAt     DateTime?
  resolvedAt          DateTime?
  closedAt            DateTime?
  metadata            Json?
  isVerified          Boolean           @default(false)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  // Relations
  categoryId          String?
  category            SupportCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  priorityId          String?
  priority            SupportPriority?  @relation(fields: [priorityId], references: [id], onDelete: SetNull)
  statusId            String
  status              SupportStatus     @relation(fields: [statusId], references: [id])
  assignedToId        String?
  assignedTo          User?             @relation("AssignedTickets", fields: [assignedToId], references: [id], onDelete: SetNull)
  contactId           String?           // Link to CRM Contact
  clientId            String?           // Link to CRM Client
  replies             SupportReply[]
  attachments         SupportAttachment[]
  ratings             SupportRating[]

  @@index([email])
  @@index([statusId])
  @@index([priorityId])
  @@index([categoryId])
  @@index([assignedToId])
  @@index([createdAt])
  @@index([source])
  @@map("support_tickets")
}

model SupportReply {
  id          String         @id @default(cuid())
  body        String         @db.Text
  isInternal  Boolean        @default(false) // Staff-only notes
  isStaff     Boolean        @default(false)
  staffName   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relations
  ticketId    String
  ticket      SupportTicket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId    String?        // User who replied (null for customer)
  author      User?          @relation(fields: [authorId], references: [id], onDelete: SetNull)
  attachments SupportAttachment[]

  @@index([ticketId])
  @@index([createdAt])
  @@map("support_replies")
}

model SupportAttachment {
  id          String        @id @default(cuid())
  fileName    String
  fileSize    Int
  mimeType    String
  url         String
  storageKey  String?
  createdAt   DateTime      @default(now())

  // Relations
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  replyId     String?
  reply       SupportReply? @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("support_attachments")
}

model SupportMacro {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  body        String   @db.Text
  category    String?  // welcome, password_reset, booking, payment, project_started, project_completed, general
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([sortOrder])
  @@map("support_macros")
}

model SupportRating {
  id          String        @id @default(cuid())
  rating      Int           // 1-5
  comment     String?
  createdAt   DateTime      @default(now())

  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([ticketId])
  @@map("support_ratings")
}

model SupportSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("support_settings")
}

model SupportKnowledgeCategory {
  id          String                     @id @default(cuid())
  name        String
  slug        String                     @unique
  description String?
  icon        String?
  color       String?
  order       Int                        @default(0)
  isActive    Boolean                    @default(true)
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  articles    SupportKnowledgeArticle[] @relation("KBCategoryArticles")

  @@index([order])
  @@index([isActive])
  @@map("support_knowledge_categories")
}

model SupportKnowledgeArticle {
  id            String                   @id @default(cuid())
  title         String
  slug          String                   @unique
  excerpt       String?
  content       String                   @db.Text
  imageUrl      String?
  videoUrl      String?
  readingTime   Int?                     // Minutes
  tags          String?                  // JSON array
  published     Boolean                  @default(false)
  viewCount     Int                      @default(0)
  helpfulCount  Int                      @default(0)
  notHelpfulCount Int                    @default(0)
  sortOrder     Int                      @default(0)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  // Relations
  categoryId    String?
  category      SupportKnowledgeCategory? @relation("KBCategoryArticles", fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([published])
  @@index([slug])
  @@map("support_knowledge_articles")
}

model FAQ {
  id          String   @id @default(cuid())
  question    String
  answer      String   @db.Text
  category    String?  // general, billing, technical, account, support, other
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([sortOrder])
  @@index([isActive])
  @@map("faqs")
}
